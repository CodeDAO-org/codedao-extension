  reactStrictMode: true,
  swcMinify: true,
  async headers() {
    return [
      {
        source: '/api/webhook',
        headers: [
          {
            key: 'Access-Control-Allow-Origin',
            value: '*',
          },
          {
            key: 'Access-Control-Allow-Methods',
            value: 'POST, OPTIONS',
          },
          {
            key: 'Access-Control-Allow-Headers',
            value: 'Content-Type, X-GitHub-Event, X-GitHub-Delivery',
          },
        ],
      },
    ];
  },
};

module.exports = nextConfig;

